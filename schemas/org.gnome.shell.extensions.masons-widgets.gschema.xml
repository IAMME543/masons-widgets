<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema
    id="org.gnome.shell.extensions.masons-widgets"
    path="/org/gnome/shell/extensions/masons-widgets/">

    <key name="widget-size" type="i">
      <default>300</default>
      <summary>Widget size</summary>
      <description>Size of each widget cell.</description>
    </key>

    <key name="inner-spacing" type="i">
      <default>12</default>
      <summary>The spacing between widgets.</summary>
    </key>
        <key name="outer-spacing" type="i">
      <default>26</default>
      <summary>The spacing between the widget grid and the edge of the screen.</summary>
    </key>
    <key name="widget-layout" type="s">
    <default>'[{"id": "base-drawing-widget","x": 5,"y": 0,"w": 1,"h": 1}]'</default></key>

  </schema>
</schemalist>